{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "**/build/**",
    "**/coverage/**",
    "**/dist/**",
    "**/.next/**",
    "**/.expo/**",
    "**/node_modules/**"
  ],
  "plugins": ["typescript", "react", "jest"],
  "rules": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  }
}
